# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=4chan

# JWT
JWT_SECRET=changeme_jwt_secret_32_chars_minimum
JWT_REFRESH_SECRET=changeme_jwt_refresh_secret_32_chars_minimum

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio

# Grafana
GRAFANA_ADMIN_PASSWORD=changeme_grafana

# Rate Limiting (nginx)
RATE_LIMIT_ENABLED=true

# Frontend
NODE_ENV=development
VITE_API_URL=http://localhost/api/v1
VITE_AUTH_URL=http://localhost/api/v1/auth
VITE_FILES_URL=http://localhost/api/v1/files

# File Service
FILE_STORAGE_TYPE=local
FILE_STORAGE_PATH=/app/uploads

# Media Processor
APP_SERVER__HOST=0.0.0.0
APP_SERVER__PORT=8081
