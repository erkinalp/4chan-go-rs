      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Nginx Gateway",
      "type": "stat",
      "targets": [{ "expr": "up{job=\"nginx\"}", "refId": "A" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "Request Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10 }, "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(http_requests_total{job=\"api-core\"}[5m])) by (method)", "legendFormat": "{{method}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10 }, "unit": "percent" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 12,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Error Rate (%)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(http_requests_total{job=\"api-core\", status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"api-core\"}[5m])) * 100", "legendFormat": "5xx error rate", "refId": "A" },
        { "expr": "sum(rate(http_requests_total{job=\"api-core\", status=~\"4..\"}[5m])) / sum(rate(http_requests_total{job=\"api-core\"}[5m])) * 100", "legendFormat": "4xx error rate", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 20,
      "title": "Request Count by Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 20, "stacking": { "mode": "normal" } }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "id": 21,
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "title": "Requests by Status Code",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(increase(http_requests_total{job=\"api-core\"}[5m])) by (status)", "legendFormat": "HTTP {{status}}", "refId": "A" }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["4chan-v2", "health"],
