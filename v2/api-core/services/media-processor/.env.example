# Server configuration
APP_SERVER__HOST=0.0.0.0
APP_SERVER__PORT=8081
APP_SERVER__API_PREFIX=api
APP_SERVER__API_VERSION=v1

# Database configuration
APP_DATABASE__URL=postgresql://username:password@localhost:5432/4chan

# Redis configuration
APP_REDIS__HOST=redis
APP_REDIS__PORT=6379
APP_REDIS__PASSWORD=
APP_REDIS__DB=0

# Redis for rate limiting
REDIS_URL=redis://redis:6379

# JWT configuration
APP_JWT__SECRET=your-secret-key-here
APP_JWT__EXPIRATION_HOURS=24
APP_JWT__REFRESH_HOURS=168
APP_JWT__ISSUER=4chan-v2

# S3 configuration
APP_S3__ENDPOINT=http://localhost:9000
APP_S3__REGION=us-east-1
APP_S3__ACCESS_KEY=minioadmin
APP_S3__SECRET_KEY=minioadmin
APP_S3__BUCKET=4chan-media

# CORS configuration
APP_CORS__ALLOWED_ORIGINS=http://localhost:3000

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_SECOND=10
RATE_LIMIT_BURST_SIZE=20
RATE_LIMIT_IP_HEADER=X-Real-IP

# Logging
LOG_LEVEL=info

# Environment
ENVIRONMENT=development
