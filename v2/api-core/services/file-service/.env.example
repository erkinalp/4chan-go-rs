# Environment
ENVIRONMENT=development
LOG_LEVEL=info

# Server configuration
PORT=8080
READ_TIMEOUT_SECONDS=10
WRITE_TIMEOUT_SECONDS=30
IDLE_TIMEOUT_SECONDS=120
API_PREFIX=api
API_VERSION=v1

# Database configuration
DATABASE_URL=postgresql://username:password@localhost:5432/4chan
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=300

# Redis configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MinIO/S3 configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=4chan-files
MINIO_USE_SSL=false

# JWT configuration
JWT_SECRET=your-secret-key-here
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_REFRESH_HOURS=168
JWT_ISSUER=4chan-v2

# CAPTCHA configuration
CAPTCHA_SECRET_KEY=your-captcha-secret
CAPTCHA_SITE_KEY=your-captcha-site-key
CAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify

# CORS configuration
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type
CORS_MAX_AGE=86400

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=50
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_IP_HEADER=X-Real-IP

# Malware scanner
MALWARE_SCANNER_ENABLED=true
MALWARE_SCANNER_FAIL_OPEN=false
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
